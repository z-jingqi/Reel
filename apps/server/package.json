{
  "name": "@reel/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply reel --local",
    "db:migrate:remote": "wrangler d1 migrations apply reel --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.1",
    "@reel/ai-core": "workspace:*",
    "@reel/database": "workspace:*",
    "@reel/shared": "workspace:*",
    "ai": "^4.0.13",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.91.0"
  }
}
